# Frontend env vars consumidas en runtime (prefix EXPO_PUBLIC_ obligatorio
# para que Metro las inyecte en el bundle).
# Copiar a .env y completar con valores reales. NO commitear .env.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
EXPO_PUBLIC_BACKEND_URL=http://localhost:8000
